DATABASE_URL="postgresql://postgres:postgres@localhost:5432/reelix?schema=public"
# Used by `prisma migrate`. For Supabase, set this to the **direct** connection (port 5432).
# For local Postgres, leave equal to DATABASE_URL.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/reelix?schema=public"
JWT_ACCESS_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL="30d"
PORT=4000
CORS_ORIGIN="*"
NODE_ENV="development"
