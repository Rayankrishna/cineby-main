generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  history       WatchHistoryItem[]
  watchlist     WatchlistItem[]
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

enum MediaType {
  movie
  tv
}

model WatchHistoryItem {
  id               String    @id @default(uuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tmdbId           Int
  mediaType        MediaType
  seasonNumber     Int?
  episodeNumber    Int?
  progressSeconds  Int       @default(0)
  durationSeconds  Int?
  completed        Boolean   @default(false)
  title            String?
  posterPath       String?
  backdropPath     String?
  watchedAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([userId, tmdbId, mediaType, seasonNumber, episodeNumber], name: "userId_tmdbId_mediaType_seasonNumber_episodeNumber")
  @@index([userId, updatedAt])
}

/// Global, crowd-sourced ranking of which embed provider has worked for a
/// given TMDB title. Every successful native-player init pings POST
/// /server-votes which upserts here (incrementing successCount). The client
/// queries GET /server-votes/{tmdbId} on detail-page mount and pre-selects
/// the highest-ranked provider, so subsequent users get the source most
/// likely to work without having to discover it by trial.
model ServerVote {
  id           String    @id @default(uuid())
  tmdbId       Int
  mediaType    MediaType
  serverName   String
  successCount Int       @default(0)
  lastSuccess  DateTime  @default(now())

  @@unique([tmdbId, mediaType, serverName], name: "tmdbId_mediaType_serverName")
  @@index([tmdbId, mediaType])
}

model WatchlistItem {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tmdbId     Int
  mediaType  MediaType
  title      String?
  posterPath String?
  addedAt    DateTime  @default(now())

  @@unique([userId, tmdbId, mediaType], name: "userId_tmdbId_mediaType")
  @@index([userId, addedAt])
}
